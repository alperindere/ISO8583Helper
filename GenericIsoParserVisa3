                41: { name: 'Card Acceptor Terminal ID', type: 'FIXED', format: 'ans', len: 8, encoding: 'EBCDIC', desc: 'Terminal ID (EBCDIC!)' },
                42: { name: 'Card Acceptor ID Code', type: 'FIXED', format: 'ans', len: 15, encoding: 'EBCDIC', desc: 'Merchant ID (EBCDIC!)' },
                43: { name: 'Card Acceptor Name/Location', type: 'FIXED', format: 'ans', len: 40, encoding: 'EBCDIC', desc: 'Merchant name (EBCDIC!)' },
                48: { name: 'Additional Data - Private', type: 'LLLVAR', format: 'ans', maxLen: 999, encoding: 'ASCII', desc: 'Network-specific' },
                49: { name: 'Currency Code, Transaction', type: 'FIXED', format: 'n', len: 3, encoding: 'ASCII', desc: 'ISO 4217 (840=USD, 949=TRY)' },
