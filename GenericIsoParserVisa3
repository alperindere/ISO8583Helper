                3: { name: 'Processing Code', type: 'FIXED', format: 'n', len: 6, encoding: 'ASCII', desc: 'Transaction type' },
                4: { name: 'Amount Transaction', type: 'FIXED', format: 'n', len: 12, encoding: 'ASCII', desc: 'Minor units' },
                41: { name: 'Terminal ID', type: 'FIXED', format: 'ans', len: 8, encoding: 'EBCDIC', desc: 'Terminal (EBCDIC)' },
                42: { name: 'Merchant ID', type: 'FIXED', format: 'ans', len: 15, encoding: 'EBCDIC', desc: 'Merchant (EBCDIC)' },
                43: { name: 'Card Acceptor Name/Location', type: 'FIXED', format: 'ans', len: 40, encoding: 'EBCDIC', desc: 'Name (EBCDIC)' }
            },
            BKM: {
