                4: { name: 'İşlem Tutarı', type: 'FIXED', format: 'n', len: 12, encoding: 'ASCII', desc: 'Kuruş cinsinden' },
                41: { name: 'Terminal ID', type: 'FIXED', format: 'ans', len: 8, encoding: 'EBCDIC', desc: 'Terminal (EBCDIC)' },
