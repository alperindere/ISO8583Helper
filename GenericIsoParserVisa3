        function ISO8583Parser() {
            const [network, setNetwork] = useState('VISA');
            const [encoding, setEncoding] = useState('ASCII'); // ASCII or EBCDIC
            const [rawMessage, setRawMessage] = useState('');
            const [mti, setMti] = useState('');
            const [bitmap, setBitmap] = useState('');
            const [fields, setFields] = useState({});
            const [parsedFields, setParsedFields] = useState([]);
            const [alert, setAlert] = useState(null);
            const [generatedMessage, setGeneratedMessage] = useState('');

            const parseMessage = () => {
                try {
                    if (!rawMessage || rawMessage.length < 20) {
                        throw new Error('Mesaj çok kısa! Minimum 20 karakter gerekli.');
                    }

                    // MTI parse (always ASCII)
                    const messageMti = rawMessage.substring(0, 4);
                    setMti(messageMti);

                    // Bitmap parse (hex to binary)
                    const bitmapHex = rawMessage.substring(4, 20);
                    const bitmapBin = hexToBinary(bitmapHex);
                    setBitmap(bitmapBin);

                    // Parse fields
                    const fieldDefs = FIELD_DEFINITIONS[network];
                    const parsedData = {};
                    const fieldsArray = [];
                    let position = 20;

                    for (let i = 1; i <= 64; i++) {
                        if (bitmapBin[i - 1] === '1') {
                            const fieldDef = fieldDefs[i];
                            if (!fieldDef) continue;

                            let fieldValue = '';
                            let fieldValueHex = '';
                            let fieldLength = 0;
                            const fieldEncoding = fieldDef.encoding || 'ASCII';

                            if (fieldDef.type === 'FIXED') {
                                fieldLength = fieldDef.len;
                                
                                if (fieldEncoding === 'EBCDIC' && encoding === 'EBCDIC') {
                                    // EBCDIC field - length is in hex chars (2 hex chars = 1 byte)
                                    const hexLen = fieldLength * 2;
                                    if (position + hexLen <= rawMessage.length) {
                                        fieldValueHex = rawMessage.substring(position, position + hexLen);
                                        fieldValue = ebcdicToAscii(fieldValueHex);
                                        position += hexLen;
                                    }
                                } else if (fieldEncoding === 'BINARY' || fieldDef.format === 'b') {
                                    // Binary field - already in hex
                                    if (position + fieldLength <= rawMessage.length) {
                                        fieldValueHex = rawMessage.substring(position, position + fieldLength);
                                        fieldValue = '[HEX: ' + fieldValueHex + ']';
                                        position += fieldLength;
                                    }
                                } else {
                                    // ASCII field
                                    if (position + fieldLength <= rawMessage.length) {
                                        fieldValue = rawMessage.substring(position, position + fieldLength);
                                        fieldValueHex = asciiToHex(fieldValue);
                                        position += fieldLength;
                                    }
                                }
                            } else if (fieldDef.type === 'LLVAR') {
                                // Length indicator handling
                                if (position + 2 <= rawMessage.length) {
                                    let lenIndicator;
                                    
                                    // Check if length is in HEX format (for EBCDIC fields)
                                    if (fieldEncoding === 'EBCDIC' && encoding === 'EBCDIC') {
                                        // Try hex length first (e.g., "10" hex = 16 decimal)
                                        const lenHex = rawMessage.substring(position, position + 2);
                                        if (/^[0-9A-F]{2}$/i.test(lenHex)) {
                                            lenIndicator = parseInt(lenHex, 16); // hex to decimal
                                            position += 2;
                                        } else {
                                            // Fallback to ASCII
                                            lenIndicator = parseInt(rawMessage.substring(position, position + 2), 10);
                                            position += 2;
                                        }
                                        
                                        const hexLen = lenIndicator * 2;
                                        if (position + hexLen <= rawMessage.length) {
                                            fieldValueHex = rawMessage.substring(position, position + hexLen);
                                            fieldValue = ebcdicToAscii(fieldValueHex);
                                            position += hexLen;
                                            fieldLength = lenIndicator;
                                        }
                                    } else {
                                        // ASCII length
                                        lenIndicator = parseInt(rawMessage.substring(position, position + 2), 10);
                                        position += 2;
                                        
                                        if (position + lenIndicator <= rawMessage.length) {
                                            fieldValue = rawMessage.substring(position, position + lenIndicator);
                                            fieldValueHex = asciiToHex(fieldValue);
                                            position += lenIndicator;
                                            fieldLength = lenIndicator;
                                        }
                                    }
                                }
                            } else if (fieldDef.type === 'LLLVAR') {
                                // Length indicator (always ASCII)
                                if (position + 3 <= rawMessage.length) {
                                    const lenIndicator = parseInt(rawMessage.substring(position, position + 3));
                                    position += 3;
                                    
                                    if (fieldEncoding === 'BINARY' || fieldDef.format === 'b') {
                                        if (position + lenIndicator <= rawMessage.length) {
                                            fieldValueHex = rawMessage.substring(position, position + lenIndicator);
                                            fieldValue = '[HEX: ' + fieldValueHex + ']';
                                            position += lenIndicator;
                                            fieldLength = lenIndicator;
                                        }
                                    } else if (fieldEncoding === 'EBCDIC' && encoding === 'EBCDIC') {
                                        const hexLen = lenIndicator * 2;
                                        if (position + hexLen <= rawMessage.length) {
                                            fieldValueHex = rawMessage.substring(position, position + hexLen);
                                            fieldValue = ebcdicToAscii(fieldValueHex);
                                            position += hexLen;
                                            fieldLength = lenIndicator;
                                        }
                                    } else {
                                        if (position + lenIndicator <= rawMessage.length) {
                                            fieldValue = rawMessage.substring(position, position + lenIndicator);
                                            fieldValueHex = asciiToHex(fieldValue);
                                            position += lenIndicator;
                                            fieldLength = lenIndicator;
                                        }
                                    }
                                }
                            }

                            parsedData[i] = fieldValue;
                            fieldsArray.push({
                                number: i,
                                name: fieldDef.name,
                                value: fieldValue,
                                valueHex: fieldValueHex,
                                type: fieldDef.type,
                                format: fieldDef.format,
                                encoding: fieldEncoding,
                                description: fieldDef.desc,
                                length: fieldLength
                            });
                        }
                    }

                    setFields(parsedData);
                    setParsedFields(fieldsArray);
                    setAlert({ type: 'success', message: `✓ Mesaj başarıyla parse edildi! ${fieldsArray.length} field bulundu. (${network} / ${encoding})` });

                } catch (error) {
                    setAlert({ type: 'error', message: `✗ Parse hatası: ${error.message}` });
                }
            };

            const generateMessage = () => {
                try {
                    if (!mti || mti.length !== 4) {
                        throw new Error('MTI 4 karakter olmalı!');
                    }

                    // Create bitmap
                    const fieldNumbers = Object.keys(fields).map(Number).sort((a, b) => a - b);
                    let bitmapBin = '';
                    for (let i = 1; i <= 64; i++) {
                        bitmapBin += fieldNumbers.includes(i) ? '1' : '0';
                    }
                    const bitmapHex = binaryToHex(bitmapBin);

                    // Build message
                    let message = mti + bitmapHex;
                    const fieldDefs = FIELD_DEFINITIONS[network];

                    for (const fieldNum of fieldNumbers) {
                        const fieldDef = fieldDefs[fieldNum];
                        const fieldValue = fields[fieldNum] || '';
                        const fieldEncoding = fieldDef.encoding || 'ASCII';

                        if (fieldDef.type === 'FIXED') {
                            const paddedValue = fieldValue.padEnd(fieldDef.len, ' ').substring(0, fieldDef.len);
                            
                            if (fieldEncoding === 'EBCDIC' && encoding === 'EBCDIC') {
                                message += asciiToEbcdic(paddedValue);
                            } else if (fieldEncoding === 'BINARY' || fieldDef.format === 'b') {
                                message += paddedValue; // Already hex
                            } else {
                                message += paddedValue; // ASCII
                            }
                        } else if (fieldDef.type === 'LLVAR') {
                            const len = fieldValue.length.toString().padStart(2, '0');
                            message += len;
                            
                            if (fieldEncoding === 'EBCDIC' && encoding === 'EBCDIC') {
                                message += asciiToEbcdic(fieldValue);
                            } else {
                                message += fieldValue;
                            }
                        } else if (fieldDef.type === 'LLLVAR') {
                            const len = fieldValue.length.toString().padStart(3, '0');
                            message += len;
                            
                            if (fieldEncoding === 'BINARY' || fieldDef.format === 'b') {
                                message += fieldValue; // Already hex
                            } else if (fieldEncoding === 'EBCDIC' && encoding === 'EBCDIC') {
                                message += asciiToEbcdic(fieldValue);
                            } else {
                                message += fieldValue;
                            }
                        }
                    }

                    setGeneratedMessage(message);
                    setAlert({ type: 'success', message: `✓ Mesaj başarıyla oluşturuldu! (${encoding} encoding)` });

                } catch (error) {
                    setAlert({ type: 'error', message: `✗ Oluşturma hatası: ${error.message}` });
                }
            };

            const hexToBinary = (hex) => {
                return hex.split('').map(h => {
                    return parseInt(h, 16).toString(2).padStart(4, '0');
                }).join('');
            };

            const binaryToHex = (bin) => {
                let hex = '';
                for (let i = 0; i < bin.length; i += 4) {
                    hex += parseInt(bin.substr(i, 4), 2).toString(16).toUpperCase();
                }
                return hex;
            };

            const updateField = (fieldNum, value) => {
                setFields(prev => ({
                    ...prev,
                    [fieldNum]: value
                }));
            };

            const addField = (fieldNum) => {
                if (!fields[fieldNum]) {
                    setFields(prev => ({
                        ...prev,
                        [fieldNum]: ''
                    }));
                }
            };

            const loadExample = (exampleMsg) => {
                setRawMessage(exampleMsg);
                setAlert({ type: 'info', message: 'Örnek mesaj yüklendi. "Parse Et" butonuna tıklayın.' });
            };

            const clearAll = () => {
                setRawMessage('');
                setMti('');
                setBitmap('');
                setFields({});
                setParsedFields([]);
                setGeneratedMessage('');
                setAlert(null);
            };

            const fieldDefs = FIELD_DEFINITIONS[network];
            const availableFields = Object.keys(fieldDefs).map(Number).sort((a, b) => a - b);

            return (
                <div className="container">
                    <div className="header">
                        <div className="header-left">
                            <h1>🏦 ISO 8583 Message Parser & Builder</h1>
                            <p>Visa, Mastercard, BKM - ASCII/EBCDIC Support</p>
                        </div>
                        <div className="header-right">
                            <h2>Switch & Takas</h2>
                            <p>Yapı Kredi Teknoloji</p>
                        </div>
                    </div>

                    <div className="controls-bar">
                        <div className="control-group">
                            <span className="control-label">Network:</span>
                            <button
                                className={`network-btn ${network === 'VISA' ? 'active' : ''}`}
                                onClick={() => setNetwork('VISA')}
                            >
                                <div className="network-icon visa"></div>
                                VISA
                            </button>
                            <button
                                className={`network-btn ${network === 'MASTERCARD' ? 'active' : ''}`}
                                onClick={() => setNetwork('MASTERCARD')}
                            >
                                <div className="network-icon mastercard"></div>
                                Mastercard
                            </button>
                            <button
                                className={`network-btn ${network === 'BKM' ? 'active' : ''}`}
                                onClick={() => setNetwork('BKM')}
                            >
                                <div className="network-icon bkm"></div>
                                BKM
                            </button>
                        </div>

                        <div className="control-group">
                            <span className="control-label">Encoding:</span>
                            <button
                                className={`encoding-btn ${encoding === 'ASCII' ? 'active' : ''}`}
                                onClick={() => setEncoding('ASCII')}
                            >
                                ASCII
                            </button>
                            <button
                                className={`encoding-btn ${encoding === 'EBCDIC' ? 'active' : ''}`}
                                onClick={() => setEncoding('EBCDIC')}
                            >
                                EBCDIC
                            </button>
                        </div>
                    </div>

                    {alert && (
                        <div style={{ padding: '20px 30px' }}>
                            <div className={`alert alert-${alert.type}`}>
                                {alert.message}
                            </div>
                        </div>
                    )}

                    {encoding === 'EBCDIC' && (
                        <div style={{ padding: '0 30px 20px 30px' }}>
                            <div className="encoding-info">
                                ⚠️ <strong>EBCDIC Mode:</strong> F41 (Terminal ID), F42 (Merchant ID), F43 (Merchant Name/Location) EBCDIC hex formatında parse edilecek/oluşturulacak.
                            </div>
                        </div>
                    )}

                    <div className="content">
                        <div className="panel panel-left">
                            <h2>📥 Parse Mesaj</h2>
                            
                            <div className="input-group">
                                <label>ISO 8583 Mesajı (Hex/ASCII/EBCDIC)</label>
                                <textarea
                                    value={rawMessage}
                                    onChange={(e) => setRawMessage(e.target.value)}
                                    placeholder={encoding === 'EBCDIC' ? 
                                        "EBCDIC örnek: 0100...E3C5D9D4F0F0F0F1..." : 
                                        "ASCII örnek: 0100...TERM0001..."}
                                />
                            </div>

                            <div className="btn-group">
                                <button className="btn btn-primary" onClick={parseMessage}>
                                    🔍 Parse Et
                                </button>
                                <button className="btn btn-secondary" onClick={clearAll}>
                                    🗑️ Temizle
                                </button>
                            </div>

                            <div className="example-messages">
                                <h4>📋 Örnek Mesajlar ({network} - {encoding})</h4>
                                {Object.entries(EXAMPLE_MESSAGES[network] || {}).map(([name, msg]) => (
                                    <button
                                        key={name}
                                        className="example-btn"
                                        onClick={() => loadExample(msg)}
                                    >
                                        {name}
                                    </button>
                                ))}
                            </div>

                            {bitmap && (
                                <>
                                    <h2 style={{ marginTop: '30px' }}>📊 Parse Sonucu</h2>
                                    
                                    <div className="stats">
                                        <div className="stat-card">
                                            <div className="stat-value">{mti}</div>
                                            <div className="stat-label">MTI</div>
                                        </div>
                                        <div className="stat-card">
                                            <div className="stat-value">{parsedFields.length}</div>
                                            <div className="stat-label">Field Sayısı</div>
                                        </div>
                                        <div className="stat-card">
                                            <div className="stat-value">{rawMessage.length}</div>
                                            <div className="stat-label">Mesaj Uzunluğu</div>
                                        </div>
                                    </div>

                                    <div>
                                        <strong style={{ fontSize: '14px', display: 'block', marginBottom: '8px' }}>
                                            Bitmap (Binary):
                                        </strong>
                                        <div className="bitmap-display">
                                            {bitmap.match(/.{1,8}/g).join(' ')}
                                        </div>
                                    </div>

                                    <div className="fields-container scrollbar">
                                        {parsedFields.map(field => (
                                            <div key={field.number} className="field-row">
                                                <div className="field-header">
                                                    <span className="field-number">
                                                        Field {field.number}
                                                        {field.encoding === 'EBCDIC' && (
                                                            <span className="field-encoding">EBCDIC</span>
                                                        )}
                                                        {field.encoding === 'BINARY' && (
                                                            <span className="field-encoding">BINARY</span>
                                                        )}
                                                    </span>
                                                    <span className="field-type">{field.type} ({field.format})</span>
                                                </div>
                                                <div className="field-name">{field.name}</div>
                                                {field.description && (
                                                    <div className="field-description">{field.description}</div>
                                                )}
                                                <div style={{ marginTop: '8px', fontFamily: 'Courier New', fontSize: '13px', color: '#212529', wordBreak: 'break-all' }}>
                                                    <strong>ASCII:</strong> {field.value}
                                                </div>
                                                {field.valueHex && (
                                                    <div className="hex-display">
                                                        <strong>HEX:</strong> {field.valueHex}
                                                    </div>
                                                )}
                                            </div>
                                        ))}
                                    </div>
                                </>
                            )}
                        </div>

                        <div className="panel">
                            <h2>🔨 Yeni Mesaj Oluştur</h2>

                            <div className="input-group">
                                <label>MTI (Message Type Indicator)</label>
                                <input
                                    type="text"
                                    value={mti}
                                    onChange={(e) => setMti(e.target.value.substring(0, 4))}
                                    placeholder="0100, 0110, 0200, 0210..."
                                    maxLength="4"
                                    style={{ width: '100%', padding: '10px', borderRadius: '6px', border: '2px solid #dee2e6', fontFamily: 'Courier New', fontSize: '14px' }}
                                />
                            </div>

                            <div className="input-group">
                                <label>Field Ekle</label>
                                <select
                                    onChange={(e) => {
                                        if (e.target.value) {
                                            addField(parseInt(e.target.value));
                                            e.target.value = '';
                                        }
                                    }}
                                    style={{ padding: '10px', borderRadius: '6px', border: '2px solid #dee2e6', fontSize: '14px', width: '100%' }}
                                >
                                    <option value="">-- Field Seçin --</option>
                                    {availableFields.map(num => (
                                        <option key={num} value={num}>
                                            Field {num} - {fieldDefs[num].name} {fieldDefs[num].encoding === 'EBCDIC' ? '(EBCDIC)' : ''}
                                        </option>
                                    ))}
                                </select>
                            </div>

                            <div className="fields-container scrollbar">
                                {Object.keys(fields).sort((a, b) => a - b).map(fieldNum => {
                                    const num = parseInt(fieldNum);
                                    const fieldDef = fieldDefs[num];
                                    return (
                                        <div key={num} className="field-row">
                                            <div className="field-header">
                                                <span className="field-number">
                                                    Field {num}
                                                    {fieldDef.encoding === 'EBCDIC' && (
                                                        <span className="field-encoding">EBCDIC</span>
                                                    )}
                                                </span>
                                                <span className="field-type">{fieldDef.type} ({fieldDef.format})</span>
                                            </div>
                                            <div className="field-name">{fieldDef.name}</div>
                                            {fieldDef.desc && (
                                                <div className="field-description">{fieldDef.desc}</div>
                                            )}
                                            <div className="field-input">
                                                <input
                                                    type="text"
                                                    value={fields[num]}
                                                    onChange={(e) => updateField(num, e.target.value)}
                                                    placeholder={`Max: ${fieldDef.maxLen || fieldDef.len}` + (fieldDef.encoding === 'EBCDIC' && encoding === 'EBCDIC' ? ' (ASCII girişi, EBCDIC hex çıkışı)' : '')}
                                                />
                                                <button
                                                    className="btn btn-secondary"
                                                    style={{ padding: '8px 12px', fontSize: '12px' }}
                                                    onClick={() => {
                                                        const newFields = { ...fields };
                                                        delete newFields[num];
                                                        setFields(newFields);
                                                    }}
                                                >
                                                    ✕
                                                </button>
                                            </div>
                                        </div>
                                    );
                                })}
                            </div>

                            <div className="btn-group">
                                <button className="btn btn-success" onClick={generateMessage}>
                                    ⚙️ Mesaj Oluştur
                                </button>
                            </div>

                            {generatedMessage && (
                                <div style={{ marginTop: '20px' }}>
                                    <label style={{ display: 'block', marginBottom: '8px', fontWeight: '600' }}>
                                        📤 Oluşturulan Mesaj ({encoding}):
                                    </label>
                                    <textarea
                                        value={generatedMessage}
                                        readOnly
                                        style={{ minHeight: '120px', background: '#f8f9fa', fontWeight: 'bold' }}
                                        onClick={(e) => e.target.select()}
                                    />
                                    <button
                                        className="btn btn-primary"
                                        style={{ marginTop: '10px', width: '100%' }}
                                        onClick={() => {
                                            navigator.clipboard.writeText(generatedMessage);
                                            setAlert({ type: 'success', message: '✓ Mesaj panoya kopyalandı!' });
                                        }}
                                    >
                                        📋 Panoya Kopyala
                                    </button>
                                </div>
                            )}
                        </div>
                    </div>

                    <div className="footer">
                        <div className="footer-content">
                            © 2025 Yapı Kredi Teknoloji - Switch & Takas Ekibi - ISO 8583 Parser v2.1 (ASCII/EBCDIC)
                        </div>
                    </div>
                </div>
            );
        }

        ReactDOM.render(<ISO8583Parser />, document.getElementById('root'));
    </script>
</body>
</html>
