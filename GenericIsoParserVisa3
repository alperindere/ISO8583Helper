        // Example messages (ASCII representation)
        const EXAMPLE_MESSAGES = {
            VISA: {
                'Authorization Request (0100) - ASCII': '0100723405412AC180040000000000000016453212345678901000000000000010000021513453012345613453002152512541105100081234560012345678901TERM0001123456789012345TEST MERCHANT       ISTANBUL        TR94909950500000008000000',
