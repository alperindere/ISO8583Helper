 WITH this_week AS (
    SELECT
        response_code,
        COUNT(*) AS cnt_this_week
    FROM txn_acquirer
    WHERE trunc(insert_date) >= trunc(sysdate) - 7
      AND trunc(insert_date) <  trunc(sysdate)
    GROUP BY response_code
),
last_week AS (
    SELECT
        response_code,
        COUNT(*) AS cnt_last_week
    FROM txn_acquirer
    WHERE trunc(insert_date) >= trunc(sysdate) - 14
      AND trunc(insert_date) <  trunc(sysdate) - 7
    GROUP BY response_code
),
combined AS (
    SELECT
        COALESCE(t.response_code, l.response_code) AS response_code,
        NVL(t.cnt_this_week, 0)                    AS cnt_this_week,
        NVL(l.cnt_last_week, 0)                    AS cnt_last_week
    FROM this_week t
    FULL OUTER JOIN last_week l
        ON t.response_code = l.response_code
)
SELECT
    response_code,
    cnt_this_week,
    cnt_last_week,
    (cnt_this_week - cnt_last_week)                          AS fark,
    CASE
        WHEN cnt_last_week = 0 THEN NULL
        ELSE ROUND(
            (cnt_this_week - cnt_last_week) / cnt_last_week * 100,
            2
        )
    END                                                       AS degisim_yuzde,
    CASE
        WHEN cnt_this_week > cnt_last_week THEN '↑ ARTTI'
        WHEN cnt_this_week < cnt_last_week THEN '↓ AZALDI'
        ELSE '= AYNI'
    END                                                       AS trend
FROM combined
ORDER BY ABS(cnt_this_week - cnt_last_week) DESC;





WITH today AS (
    SELECT
        response_code,
        COUNT(*) AS cnt_today
    FROM txn_acquirer
    WHERE trunc(insert_date) = trunc(sysdate)
    GROUP BY response_code
),
yesterday AS (
    SELECT
        response_code,
        COUNT(*) AS cnt_yesterday
    FROM txn_acquirer
    WHERE trunc(insert_date) = trunc(sysdate) - 1
    GROUP BY response_code
),
combined AS (
    SELECT
        COALESCE(t.response_code, y.response_code) AS response_code,
        NVL(t.cnt_today,     0)                    AS cnt_today,
        NVL(y.cnt_yesterday, 0)                    AS cnt_yesterday
    FROM today t
    FULL OUTER JOIN yesterday y
        ON t.response_code = y.response_code
)
SELECT
    response_code,
    cnt_today,
    cnt_yesterday,
    (cnt_today - cnt_yesterday)                           AS fark,
    CASE
        WHEN cnt_yesterday = 0 THEN NULL
        ELSE ROUND(
            (cnt_today - cnt_yesterday) / cnt_yesterday * 100,
            2
        )
    END                                                    AS degisim_yuzde,
    CASE
        WHEN cnt_today > cnt_yesterday THEN '↑ ARTTI'
        WHEN cnt_today < cnt_yesterday THEN '↓ AZALDI'
        ELSE '= AYNI'
    END                                                    AS trend
FROM combined
ORDER BY ABS(cnt_today - cnt_yesterday) DESC;



WITH last_hour AS (
