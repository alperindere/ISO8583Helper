WITH two_hours_ago AS (
    SELECT
        response_code,
        COUNT(*) AS cnt_two_hours_ago
    FROM txn_acquirer
    WHERE insert_date >= sysdate - 3/24
      AND insert_date <  sysdate - 2/24
    GROUP BY response_code
),
one_hour_ago AS (
    SELECT
        response_code,
        COUNT(*) AS cnt_one_hour_ago
    FROM txn_acquirer
    WHERE insert_date >= sysdate - 2/24
      AND insert_date <  sysdate - 1/24
    GROUP BY response_code
),
combined AS (
    SELECT
        COALESCE(o.response_code, t.response_code) AS response_code,
        NVL(o.cnt_one_hour_ago, 0)                 AS cnt_one_hour_ago,
        NVL(t.cnt_two_hours_ago, 0)                AS cnt_two_hours_ago
    FROM one_hour_ago o
    FULL OUTER JOIN two_hours_ago t
        ON o.response_code = t.response_code
)
SELECT
    response_code,
    cnt_one_hour_ago,
    cnt_two_hours_ago,
    (cnt_one_hour_ago - cnt_two_hours_ago)                            AS fark,
    CASE
        WHEN cnt_two_hours_ago = 0 THEN NULL
        ELSE ROUND(
            (cnt_one_hour_ago - cnt_two_hours_ago) / cnt_two_hours_ago * 100,
            2
        )
    END                                                                AS degisim_yuzde,
    CASE
        WHEN cnt_one_hour_ago > cnt_two_hours_ago THEN '↑ ARTTI'
        WHEN cnt_one_hour_ago < cnt_two_hours_ago THEN '↓ AZALDI'
        ELSE '= AYNI'
    END                                                                AS trend
FROM combined
ORDER BY ABS(cnt_one_hour_ago - cnt_two_hours_ago) DESC;




SELECT
    COALESCE(p.response_code, c.response_code)  AS response_code,
    NVL(p.cnt_prev, 0)                          AS cnt_gecen_hafta,
    NVL(c.cnt_curr, 0)                          AS cnt_bu_hafta,
    (NVL(c.cnt_curr, 0) - NVL(p.cnt_prev, 0))  AS fark,
    CASE
        WHEN NVL(p.cnt_prev, 0) = 0 THEN NULL
        ELSE ROUND(
            (NVL(c.cnt_curr, 0) - NVL(p.cnt_prev, 0)) / p.cnt_prev * 100,
            2
        )
    END                                          AS degisim_yuzde,
    CASE
        WHEN c.response_code IS NULL THEN 'KAYBOLDU ❌'
        WHEN p.response_code IS NULL THEN 'YENİ ÇIKTI 🆕'
        WHEN c.cnt_curr > p.cnt_prev  THEN '↑ ARTTI'
        WHEN c.cnt_curr < p.cnt_prev  THEN '↓ AZALDI'
        ELSE '= AYNI'
    END                                          AS durum,
    CASE
        WHEN c.response_code IS NULL THEN
            (SELECT MAX(insert_date)
             FROM txn_acquirer
             WHERE response_code = p.response_code)
        ELSE NULL
    END                                          AS son_gorulme_zamani
FROM
    (
        -- Geçen haftanın aynı günü
        SELECT response_code, COUNT(*) AS cnt_prev
        FROM txn_acquirer
        WHERE trunc(insert_date) = trunc(sysdate) - 7
        GROUP BY response_code
    ) p
FULL OUTER JOIN
    (
        -- Bugün
        SELECT response_code, COUNT(*) AS cnt_curr
        FROM txn_acquirer
        WHERE trunc(insert_date) = trunc(sysdate)
        GROUP BY response_code
    ) c
    ON p.response_code = c.response_code
ORDER BY
    CASE
        WHEN c.response_code IS NULL THEN 1  -- önce kaybolanlar
        WHEN p.response_code IS NULL THEN 2  -- sonra yeni çıkanlar
        ELSE 3
    END,
    ABS(NVL(c.cnt_curr, 0) - NVL(p.cnt_prev, 0)) DESC;


