  <!-- ① ONLINE AUTH PHASE -->
  <div class="phase">
    <div class="phase-title auth">① Online Authorization — Real-time</div>

    <!-- STEP 1: Kanal → Gate -->
    <div class="step internal">
      <div class="step-num int">1</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag int">ISO 8583 REQUEST</span>
          <span class="dir-arrow from-ch">Kanal → Gate</span>
        </div>
        <div class="step-desc">Kanaldan gelen işlem isteği ilgili Gate'e ulaşır</div>
        <div class="gate-row">
          <div class="gate active">VTS Gate</div>
          <div class="gate active">POS Gate</div>
          <div class="gate active">MPOS Gate</div>
          <div class="gate active">ISO Gate</div>
          <div class="gate active">MNG Gate</div>
        </div>
      </div>
    </div>

    <!-- STEP 2: Kart Onus Kararı -->
    <div class="decision-box">
      <h4>⬡ KART ONUS / NOT ONUS KARARI</h4>
      <div class="step-desc" style="margin-bottom:6px;">Gate → Merkezi Routing Engine: BIN tablosuna bakılır</div>
      <div class="decision-row">
        <div class="dec-item"><b>BIN = Bizim kart</b> → Onus → İç Auth (Issuer moduna geç)</div>
        <div class="dec-item"><b>BIN = Yabancı Visa kart</b> → Not Onus → Visa Gate'e yönlendir</div>
        <div class="dec-item"><b>BIN = MC</b> → MC Gate'e yönlendir</div>
        <div class="dec-item"><b>BIN = JCB</b> → JCB Gate'e yönlendir</div>
      </div>
      <div style="font-size:0.55rem; color:var(--decision); margin-top:4px;">▶ Bu diyagram: NOT ONUS (Yabancı Visa Kart) yolu — Visa Gate devreye girer</div>
    </div>

    <!-- STEP 3: Visa Gate -->
    <div class="step internal">
      <div class="step-num int">2</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag int">ROUTING</span>
          <span class="dir-arrow internal">→ Visa Gate</span>
        </div>
        <div class="step-desc">ISO 8583 mesajı Visa Gate formatına dönüştürülür (V.I.P. spec uyumlu). EMV/F55 alanı eklenir, F63 Network Data hazırlanır.</div>
        <div class="gate-row">
          <div class="gate active">Visa Gate</div>
          <div class="gate" style="opacity:0.4">MC Gate</div>
          <div class="gate" style="opacity:0.4">BKM Gate</div>
          <div class="gate" style="opacity:0.4">JCB Gate</div>
        </div>
      </div>
    </div>

    <!-- STEP 4: 0100 → VisaNet -->
    <div class="step outbound">
      <div class="step-num out">3</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag req">0100</span>
          <span>Authorization Request</span>
          <span class="dir-arrow to-visa">→ VisaNet (V.I.P.)</span>
        </div>
        <div class="step-desc">Visa Gate TCP/TLS bağlantısı üzerinden VisaNet'e iletir</div>
        <div class="fields">
          <span class="f"><b>F2</b> PAN</span>
          <span class="f"><b>F3</b> Proc Code</span>
          <span class="f hi"><b>F4</b> Trans Amt</span>
          <span class="f"><b>F7</b> Date/Time</span>
          <span class="f hi"><b>F11</b> STAN</span>
          <span class="f"><b>F22</b> POS Entry Mode</span>
          <span class="f"><b>F41</b> Terminal ID</span>
          <span class="f hi"><b>F42</b> Merchant ID</span>
          <span class="f"><b>F43</b> Merchant Name</span>
          <span class="f"><b>F49</b> Currency</span>
          <span class="f"><b>F52</b> PIN Data</span>
          <span class="f hi"><b>F55</b> EMV/ICC Data</span>
        </div>
      </div>
    </div>

    <!-- STEP 5: 0110 ← VisaNet -->
    <div class="step inbound">
      <div class="step-num auth">4</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag rsp">0110</span>
          <span>Authorization Response</span>
          <span class="dir-arrow from-visa">← VisaNet</span>
        </div>
        <div class="step-desc">VisaNet Issuer'dan dönen cevabı iletir. Visa Gate cevabı parse eder.</div>
        <div class="fields">
          <span class="f hi"><b>F39</b> Response Code (00/51/14…)</span>
          <span class="f hi"><b>F38</b> Auth Code (6 hane)</span>
          <span class="f"><b>F55</b> ARPC (EMV)</span>
          <span class="f"><b>F44</b> Addl Resp Data</span>
        </div>
      </div>
    </div>

    <!-- STEP 6: POS'a cevap -->
    <div class="step internal">
      <div class="step-num int">5</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag int">CEVAP</span>
          <span class="dir-arrow to-ch">→ Kanala (POS/ATM…)</span>
        </div>
        <div class="step-desc">F39=00 ise POS'a onay, chip ise F55 ARPC iletilir. İşlem kaydı loglanır (Logger/Event Gate).</div>
        <div class="gate-row">
          <div class="gate active">Logger</div>
          <div class="gate active">Event Gate</div>
          <div class="gate active">Monitoring</div>
        </div>
      </div>
    </div>

    <!-- EMV/HSM Note -->
    <div style="border:1px solid rgba(14,165,233,0.15); border-radius:5px; padding:6px 10px; margin-top:4px; background:rgba(14,165,233,0.03);">
      <span style="font-size:0.56rem; color:var(--muted);">⚙ Yardımcı servisler (Online Auth sırasında): </span>
      <div class="gate-row" style="margin:4px 0 0;">
        <div class="gate">EMV Gate (ARQC doğrulama)</div>
        <div class="gate">HSM Gate (PIN şifreleme/çözme)</div>
      </div>
    </div>

  </div><!-- /auth phase -->

  <hr class="divider" style="margin:12px 0;">

  <!-- ② CLEARING PHASE -->
  <div class="phase">
    <div class="phase-title clear">② Batch Clearing — BASE II (T+0/T+1)</div>

    <!-- STEP 7: Batch hazırla -->
    <div class="step clr-in">
      <div class="step-num clr">6</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag clr">BATCH HAZIRLIK</span>
          <span class="dir-arrow internal">OCEAN İç İşlem</span>
        </div>
        <div class="step-desc">Gün sonu: Online auth kaydı olan tüm Visa işlemler toplanır. Settlement Amount (F5) ve FX kuru hesaplanır.</div>
      </div>
    </div>

    <!-- STEP 8: 0220 → BASE II -->
    <div class="step outbound">
      <div class="step-num out">7</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag clr">0220 TC05</span>
          <span>Financial Presentment</span>
          <span class="dir-arrow to-visa">→ BASE II</span>
        </div>
        <div class="step-desc">Acquirer batch dosyasını BASE II'ye gönderir (Visa Gate üzerinden)</div>
        <div class="fields">
          <span class="f"><b>F2</b> PAN</span>
          <span class="f"><b>F3</b> Proc Code</span>
          <span class="f hi"><b>F4</b> Trans Amt</span>
          <span class="f hi"><b>F5</b> Settlement Amt</span>
          <span class="f"><b>F9</b> Conv Rate (Sett)</span>
          <span class="f"><b>F38</b> Auth Code</span>
          <span class="f"><b>F43</b> Merchant Name</span>
          <span class="f"><b>F63</b> Addl Data/TC</span>
        </div>
      </div>
    </div>

    <!-- STEP 9: 0230 ← BASE II -->
    <div class="step clr-in">
      <div class="step-num clr">8</div>
      <div class="step-body">
        <div class="step-title">
          <span class="mti-tag rsp">0230</span>
          <span>Presentment ACK</span>
          <span class="dir-arrow from-visa">← BASE II</span>
        </div>
        <div class="step-desc">BASE II kabul onayı döner. Acquirer net position hesaplanır. Interchange fee kesilir.</div>
        <div class="fields">
          <span class="f hi"><b>F39</b> 00 = Kabul</span>
          <span class="f"><b>F38</b> Auth Code</span>
        </div>
      </div>
    </div>

  </div><!-- /clearing phase -->

</div><!-- /ocean-box -->
