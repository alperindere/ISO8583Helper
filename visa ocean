</header>

<div style="max-width:1200px; margin: 0 auto 16px; display:grid; grid-template-columns:200px 1fr 180px; gap:0;">
  <div class="col-header src">Kanal / Kaynak</div>
  <div class="col-header ocean" style="margin:0 8px;">OCEAN (Sizin Sisteminiz)</div>
