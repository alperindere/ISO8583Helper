<Window x:Class="ISO8583Parser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ISO 8583 Parser - Switch &amp; Takas" Height="950" Width="1600"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="NetworkButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
        </Style>

        <Style x:Key="EncodingButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#667EEA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6C757D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E3C72" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource HeaderTextStyle}">
                        🏦 ISO 8583 Message Parser - EBCDIC/ASCII
                    </TextBlock>
                    <TextBlock Foreground="White" FontSize="14" Opacity="0.9" Margin="0,5,0,0">
                        VISA, Mastercard, BKM - Oracle Dump Support
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1" Background="#2A5298" CornerRadius="10" Padding="20,10" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center">
                            Switch & Takas
                        </TextBlock>
                        <TextBlock Foreground="White" FontSize="13" Opacity="0.9" HorizontalAlignment="Center">
                            Yapı Kredi Teknoloji
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Network Selector -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,2" Padding="20,15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Network:" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="BtnVisa" Content="VISA" Style="{StaticResource NetworkButtonStyle}" Click="NetworkButton_Click" Tag="VISA"/>
                    <Button x:Name="BtnMastercard" Content="Mastercard" Style="{StaticResource NetworkButtonStyle}" Click="NetworkButton_Click" Tag="MASTERCARD"/>
                    <Button x:Name="BtnBkm" Content="BKM" Style="{StaticResource NetworkButtonStyle}" Click="NetworkButton_Click" Tag="BKM"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Encoding:" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="BtnAscii" Content="ASCII" Style="{StaticResource EncodingButtonStyle}" Click="EncodingButton_Click" Tag="ASCII"/>
                    <Button x:Name="BtnEbcdic" Content="EBCDIC" Style="{StaticResource EncodingButtonStyle}" Click="EncodingButton_Click" Tag="EBCDIC"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Header Skip Control -->
        <Border Grid.Row="2" Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="0,0,0,2" Padding="20,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙️ Oracle Header Skip (bytes):" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <Slider x:Name="SliderHeaderSkip" Width="200" Minimum="0" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" 
                        Value="0" ValueChanged="HeaderSkip_ValueChanged" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtHeaderSkipValue" Text="0" FontWeight="Bold" FontSize="14" Margin="10,0" VerticalAlignment="Center" Width="30"/>
                <TextBlock Text="(Oracle dump için 6 byte header skip edin)" FontSize="12" Opacity="0.7" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="3" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Parse Panel -->
            <Border Background="White" CornerRadius="10" Padding="25">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0" Text="📥 Parse ISO 8583 Mesaj" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                    <!-- Input Area -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="ISO 8583 Mesajı (Hex Format)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtRawMessage" TextWrapping="Wrap" AcceptsReturn="True" Height="120"
                                FontFamily="Consolas" FontSize="12" Padding="12" BorderBrush="#DDD" BorderThickness="2"
                                VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- Buttons and Examples -->
                    <Grid Grid.Row="2" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="🔍 Parse Et" Style="{StaticResource PrimaryButtonStyle}" Click="ParseMessage_Click" Margin="0,0,10,0"/>
                            <Button Content="🗑️ Temizle" Style="{StaticResource SecondaryButtonStyle}" Click="ClearAll_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="📋 Örnek Mesajlar" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CmbExamples" Width="350" Padding="8" SelectionChanged="ExampleMessage_SelectionChanged"/>
                        </StackPanel>
                    </Grid>

                    <!-- Stats -->
                    <Grid Grid.Row="3" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#667EEA" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock x:Name="TxtMti" Text="----" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="MTI" Foreground="White" FontSize="11" HorizontalAlignment="Center" Opacity="0.9"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#667EEA" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock x:Name="TxtFieldCount" Text="0" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Fields" Foreground="White" FontSize="11" HorizontalAlignment="Center" Opacity="0.9"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#667EEA" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock x:Name="TxtMessageLength" Text="0" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center"/>
                                <TextBlock Text="Length" Foreground="White" FontSize="11" HorizontalAlignment="Center" Opacity="0.9"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="#28A745" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Bitmap" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="50">
                                    <TextBlock x:Name="TxtBitmap" TextWrapping="Wrap" Foreground="White" FontFamily="Consolas" FontSize="9"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Parsed Fields -->
                    <Border Grid.Row="4" Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📊 Parse Sonucu - Fieldlar" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ParsedFieldsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="6" Padding="15" Margin="0,0,0,10" BorderBrush="#667EEA" BorderThickness="0,0,0,3">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Field Header -->
                                                    <Grid Grid.Row="0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding FieldNumber}" Foreground="#667EEA" FontWeight="Bold" FontSize="14"/>
                                                            <Border Background="#FFC107" CornerRadius="3" Padding="4,2" Margin="8,0,0,0" Visibility="{Binding FieldEncoding, Converter={StaticResource EbcdicVisibilityConverter}}">
                                                                <TextBlock Text="EBCDIC" FontSize="10" FontWeight="Bold" Foreground="Black"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding FieldType}" Background="#E9ECEF" Padding="5,3" FontSize="11" HorizontalAlignment="Right" Foreground="#495057"/>
                                                    </Grid>

                                                    <!-- Field Name -->
                                                    <TextBlock Grid.Row="1" Text="{Binding FieldName}" FontSize="12" Foreground="#6C757D" FontWeight="SemiBold" Margin="0,8,0,4"/>

                                                    <!-- Description -->
                                                    <TextBlock Grid.Row="2" Text="{Binding FieldDescription}" FontSize="11" Foreground="#999" FontStyle="Italic" Margin="0,0,0,8"/>

                                                    <!-- ASCII Value -->
                                                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                                                        <TextBlock Text="ASCII:" FontSize="11" FontWeight="SemiBold" Foreground="#495057"/>
                                                        <TextBlock Text="{Binding FieldValue}" FontFamily="Consolas" FontSize="13" TextWrapping="Wrap" Foreground="#212529" Margin="0,4,0,0"/>
                                                    </StackPanel>

                                                    <!-- Hex Value -->
                                                    <StackPanel Grid.Row="4" Visibility="{Binding FieldValueHex, Converter={StaticResource HexVisibilityConverter}}">
                                                        <TextBlock Text="HEX:" FontSize="11" FontWeight="SemiBold" Foreground="#495057"/>
                                                        <Border Background="#1A1A2E" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding FieldValueHex}" FontFamily="Consolas" FontSize="11" Foreground="#00D9FF" TextWrapping="Wrap"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#2A5298" Padding="20,12">
            <Grid>
                <TextBlock x:Name="TxtStatus" Text="Hazır - Mesaj parse etmek için yukarıdaki alana yapıştırın" Foreground="White" FontSize="13" HorizontalAlignment="Left"/>
                <TextBlock Text="© 2025 Yapı Kredi Teknoloji - Switch &amp; Takas Ekibi" Foreground="White" FontSize="13" Opacity="0.9" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>
