<!DOCTYPE html>

<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OCEAN – Issuer Flow · Visa</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Syne:wght@400;700;800&display=swap');

:root {
–bg: #07090f;
–bg2: #0d1117;
–border: #161d2e;
–border2: #1f2d45;
–ocean-color: #00e5a0;
–visa-color: #f5a623;
–ext-color: #94a3b8;
–gate-color: #34d399;
–decision: #fb923c;
–online: #38bdf8;
–resp: #34d399;
–clear: #a78bfa;
–you: #00e5a0;
–text: #e2e8f0;
–muted: #475569;
–dim: #334155;
}

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘JetBrains Mono’, monospace;
padding: 28px 20px 40px;
min-width: 1100px;
}

header {
display: flex; align-items: center; justify-content: space-between;
max-width: 1200px; margin: 0 auto 32px;
border-bottom: 1px solid var(–border2); padding-bottom: 16px;
}
header h1 {
font-family: ‘Syne’, sans-serif; font-size: 1.5rem;
font-weight: 800; color: var(–ocean-color); letter-spacing: 0.02em;
}
header p { font-size: 0.65rem; color: var(–muted); margin-top: 4px; }
.role-badge {
padding: 6px 14px; border-radius: 6px; font-size: 0.65rem;
font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
background: rgba(0,229,160,0.15); border: 1px solid rgba(0,229,160,0.4);
color: var(–ocean-color);
}

.main-grid {
display: grid;
grid-template-columns: 180px 1fr 200px;
gap: 0;
max-width: 1200px; margin: 0 auto; align-items: start;
}

.col-header {
border-radius: 8px 8px 0 0; padding: 10px 14px;
text-align: center; font-size: 0.62rem; font-weight: 700;
letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0;
}
.col-header.visa  { background: rgba(245,166,35,0.08);  border: 1px solid rgba(245,166,35,0.3);  color: var(–visa-color); }
.col-header.ocean { background: rgba(0,229,160,0.08);   border: 1px solid rgba(0,229,160,0.3);   color: var(–ocean-color); }
.col-header.ch    { background: rgba(148,163,184,0.08); border: 1px solid #1e293b; color: var(–ext-color); }

/* VISA column (left) */
.visa-col {
padding: 12px 8px 12px 0;
display: flex; flex-direction: column; gap: 8px;
}
.visa-node {
padding: 8px 10px; border-radius: 6px;
font-size: 0.58rem; text-align: center; border: 1px solid;
}
.visa-node.vip { border-color: rgba(245,166,35,0.4); background: rgba(245,166,35,0.07); color: var(–visa-color); }
.visa-node.b2  { border-color: rgba(167,139,250,0.4); background: rgba(167,139,250,0.07); color: var(–clear); }
.visa-node.vss { border-color: rgba(52,211,153,0.3);  background: rgba(52,211,153,0.06); color: var(–resp); }
.visa-node .vn { font-weight:700; font-size:0.65rem; display:block; margin-bottom:2px; }
.visa-node .vs { color:var(–muted); font-size:0.52rem; }

/* OCEAN box */
.ocean-box {
border: 1px solid rgba(0,229,160,0.3);
border-radius: 8px; background: rgba(0,229,160,0.03);
margin: 0 8px; padding: 16px 12px; position: relative;
}
.ocean-label {
position: absolute; top: -11px; left: 14px;
background: var(–bg); padding: 0 8px;
font-family: ‘Syne’, sans-serif; font-size: 0.75rem;
font-weight: 800; color: var(–ocean-color); letter-spacing: 0.05em;
}

.phase { margin-bottom: 20px; }
.phase-title {
font-size: 0.55rem; font-weight: 700; letter-spacing: 0.14em;
text-transform: uppercase; padding: 3px 10px; border-radius: 20px;
margin-bottom: 10px; display: inline-block;
}
.phase-title.auth  { background: rgba(56,189,248,0.1);  color: var(–online); border: 1px solid rgba(56,189,248,0.25); }
.phase-title.clear { background: rgba(167,139,250,0.1); color: var(–clear);  border: 1px solid rgba(167,139,250,0.25); }

.step {
display: flex; align-items: flex-start; gap: 10px;
margin-bottom: 8px; padding: 8px 10px; border-radius: 6px;
border: 1px solid transparent; position: relative;
}
.step.inbound  { border-color: rgba(56,189,248,0.15);   background: rgba(56,189,248,0.04); }
.step.you-send { border-color: rgba(0,229,160,0.25);    background: rgba(0,229,160,0.06); box-shadow: 0 0 8px rgba(0,229,160,0.08); }
.step.internal { border-color: rgba(0,229,160,0.12);    background: rgba(0,229,160,0.03); }
.step.clr-in   { border-color: rgba(167,139,250,0.15);  background: rgba(167,139,250,0.04); }
.step.clr-you  { border-color: rgba(0,229,160,0.2);     background: rgba(0,229,160,0.05); box-shadow: 0 0 6px rgba(0,229,160,0.07); }

.step-num {
min-width: 20px; height: 20px; border-radius: 50%;
display: flex; align-items: center; justify-content: center;
font-size: 0.58rem; font-weight: 700; flex-shrink: 0; margin-top: 1px;
}
.step-num.auth { background: rgba(56,189,248,0.2);  color: var(–online); border: 1px solid rgba(56,189,248,0.4); }
.step-num.you  { background: rgba(0,229,160,0.25);  color: var(–you);    border: 1px solid rgba(0,229,160,0.5); }
.step-num.int  { background: rgba(0,229,160,0.15);  color: var(–ocean-color); border: 1px solid rgba(0,229,160,0.3); }
.step-num.clr  { background: rgba(167,139,250,0.2); color: var(–clear);  border: 1px solid rgba(167,139,250,0.4); }

.step-body { flex: 1; }
.step-title {
font-size: 0.66rem; font-weight: 700; margin-bottom: 4px;
display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
}

.mti-tag { font-size: 0.6rem; padding: 1px 7px; border-radius: 3px; font-weight: 700; }
.mti-tag.req  { background: rgba(56,189,248,0.15);  color: var(–online); }
.mti-tag.rsp  { background: rgba(0,229,160,0.2);    color: var(–you); }
.mti-tag.clr  { background: rgba(167,139,250,0.15); color: var(–clear); }
.mti-tag.int  { background: rgba(0,229,160,0.12);   color: var(–ocean-color); }

.dir-arrow {
font-size: 0.55rem; padding: 1px 6px; border-radius: 3px;
font-weight: 600; white-space: nowrap;
}
.dir-arrow.from-visa { background: rgba(245,166,35,0.1);   color: var(–visa-color); }
.dir-arrow.to-visa   { background: rgba(245,166,35,0.1);   color: var(–visa-color); }
.dir-arrow.internal  { background: rgba(0,229,160,0.1);    color: var(–ocean-color); }
.dir-arrow.to-card   { background: rgba(148,163,184,0.1);  color: var(–ext-color); }
.dir-arrow.you-label { background: rgba(0,229,160,0.15);   color: var(–you); border: 1px solid rgba(0,229,160,0.3); }

.step-desc { font-size: 0.58rem; color: var(–muted); margin-bottom: 5px; line-height: 1.5; }

.fields { display: flex; flex-wrap: wrap; gap: 3px; }
.f {
font-size: 0.52rem; padding: 1px 5px; border-radius: 3px;
background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); color: var(–dim);
}
.f b { color: var(–text); }
.f.hi { border-color: rgba(0,229,160,0.3); color: var(–you); background: rgba(0,229,160,0.06); }
.f.hi b { color: var(–you); }

/* Card type routing */
.card-route-box {
border: 1px solid rgba(251,146,60,0.3);
border-radius: 6px; background: rgba(251,146,60,0.05);
padding: 8px 12px; margin: 8px 0;
}
.card-route-box h4 { font-size: 0.62rem; font-weight: 700; color: var(–decision); margin-bottom: 6px; }
.cr-row { display: flex; gap: 6px; flex-wrap: wrap; }
.cr-item {
font-size: 0.55rem; padding: 3px 8px; border-radius: 4px;
background: rgba(251,146,60,0.07); border: 1px solid rgba(251,146,60,0.2); color: var(–text);
}
.cr-item b { color: var(–decision); }
.cr-item.active { border-color: rgba(0,229,160,0.4); background: rgba(0,229,160,0.07); }
.cr-item.active b { color: var(–you); }

/* Auth engine */
.auth-engine {
border: 1px solid rgba(0,229,160,0.2);
border-radius: 6px; background: rgba(0,229,160,0.04);
padding: 8px 12px; margin: 8px 0;
}
.auth-engine h4 { font-size: 0.62rem; font-weight: 700; color: var(–you); margin-bottom: 6px; }
.ae-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
.ae-item {
font-size: 0.56rem; padding: 3px 8px; border-radius: 4px;
background: rgba(0,229,160,0.06); border: 1px solid rgba(0,229,160,0.15);
color: var(–text); line-height: 1.4;
}
.ae-item b { color: var(–you); }

.gate-row { display: flex; gap: 6px; flex-wrap: wrap; margin: 4px 0; }
.gate {
font-size: 0.56rem; font-weight: 600; padding: 4px 10px;
border-radius: 4px; background: rgba(0,229,160,0.08);
border: 1px solid rgba(0,229,160,0.2); color: var(–you); text-align: center;
}
.gate.active { background: rgba(0,229,160,0.15); border-color: rgba(0,229,160,0.45); box-shadow: 0 0 6px rgba(0,229,160,0.12); }
.gate.neutral { background: rgba(148,163,184,0.06); border-color: #1e293b; color: var(–muted); }

/* Card holder output column */
.ch-col {
padding: 12px 0 12px 0;
display: flex; flex-direction: column; gap: 6px;
}
.ch-item {
font-size: 0.58rem; padding: 6px 10px; border-radius: 5px;
border: 1px solid #1e293b; color: var(–muted);
background: rgba(255,255,255,0.02); text-align: left;
}
.ch-item b { color: var(–text); display: block; margin-bottom: 2px; }

.divider { max-width:1200px; margin:4px auto; border:none; border-top:1px dashed var(–border2); }

.settle-summary {
max-width: 1200px; margin: 16px auto 0;
border: 1px solid rgba(0,229,160,0.2);
border-radius: 8px; background: rgba(0,229,160,0.03);
padding: 14px 18px;
display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
}
.settle-summary h4 {
grid-column: 1/4; font-size: 0.62rem; font-weight: 700;
text-transform: uppercase; letter-spacing: 0.1em;
color: var(–you); margin-bottom: 4px;
font-family: ‘Syne’, sans-serif;
}
.si { font-size: 0.58rem; color: var(–muted); line-height: 1.6; }
.si b { color: var(–text); }
.si.hi b { color: var(–you); }

footer {
max-width:1200px; margin:20px auto 0; text-align:center;
font-size:0.55rem; color:var(–muted);
border-top:1px solid var(–border); padding-top:12px;
}
</style>

</head>
